# Copy to .env and fill in. Never commit .env (already gitignored).

# --- Network ---------------------------------------------------------------

# RPC URL for the target chain (e.g., Tempo testnet).
RPC=

# (optional) Block explorer URL for verification. Leave blank if the chain
# has no Sourcify/Etherscan-compatible verifier yet.
VERIFIER_URL=

# --- Deployer --------------------------------------------------------------

# Recommended: import the deployer key once with `cast wallet import <name>`,
# then pass `--account <name>` to forge script. Do NOT put PRIVATE_KEY here.

# --- Constructor input -----------------------------------------------------

# Comma-separated, no spaces. The allowlist is set at deployment and IMMUTABLE
# afterward — list every stablecoin you want this deployment to accept up front.
# Example: RAIL0_ACCEPTED_TOKENS=0xAAA...,0xBBB...,0xCCC...
RAIL0_ACCEPTED_TOKENS=
